# Server Environment Variables
# Copy this file to .env and fill in your values.

# Server port
PORT=4000

# Node environment
NODE_ENV=development

# Supabase (required for real DB & auth)
# Get these from: https://supabase.com/dashboard → Project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-service-role-key

# Google OAuth (configured via Supabase Auth dashboard, not needed here directly)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Payment gateway
# For demo-checkout mode, no key is needed.
# Uncomment and fill for real providers:
# STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# VNPAY_TMN_CODE=your-vnpay-tmn-code
# VNPAY_HASH_SECRET=your-vnpay-hash-secret
# MOMO_PARTNER_CODE=your-momo-partner-code
# MOMO_ACCESS_KEY=your-momo-access-key
# MOMO_SECRET_KEY=your-momo-secret-key
PAYMENT_PROVIDER=demo-checkout

# Consultation form (homepage hero) → Google Sheets
# See README.md "Consultation form (Google Sheets)" for how to create this
# Apps Script Web App URL. Leave empty to log leads to the console instead
# of sending them anywhere (mock mode).
GOOGLE_SHEETS_WEBHOOK_URL=
